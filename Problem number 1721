class Solution {
public:
    ListNode* swapNodes(ListNode* head, int k) {

        ListNode* first = head;

        for (int i = 1; i < k; i++)
            first = first->next;

        ListNode* left = first;

        ListNode* right = head;

        while (first->next) {
            first = first->next;
            right = right->next;
        }

        swap(left->val, right->val);

        return head;
    }
};
